# ============================================================
# GlorySound Backend — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/glorysound_db?schema=public"

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:4000/api/auth/facebook/callback

# Cloudinary (images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AWS S3 (audio/video)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=glorysound-media

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@glorysound.ht
SMTP_PASS=your_app_password
EMAIL_FROM="GlorySound <contact@glorysound.ht>"

# Admin default (used by seed)
ADMIN_EMAIL=admin@glorysound.ht
ADMIN_PASSWORD=ChangeMe2026!

# Agent IA
ANTHROPIC_API_KEY=your_anthropic_api_key

# Agent IA — découverte multi-sources (facultatif, dégrade gracieusement si absent)
# YouTube Data API v3 : clé gratuite sur console.cloud.google.com (10000 req/j)
YOUTUBE_API_KEY=your_youtube_data_api_v3_key
# Spotify Web API (client credentials) : app gratuite sur developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
